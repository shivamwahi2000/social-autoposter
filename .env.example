# Copy this file to .env for local testing (never commit .env to git)

# Google Gemini Flash + Imagen (free tier) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# LinkedIn — https://developer.linkedin.com
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_ORG_ID=your_org_id_here          # leave blank to post to personal profile

# Instagram (Meta Graph API) — https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_USER_ID=your_instagram_user_id_here
